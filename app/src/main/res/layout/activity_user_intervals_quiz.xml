<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".user_intervals_quiz">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/black"
        android:weightSum="8"
        >
        <TextView
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:textColor="@color/white"
            android:textStyle="bold|normal"
            android:text="Intervals Quiz"
            android:gravity="center"
            android:textSize="30sp"
            >
        </TextView>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPlayInterval"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:text="Play Interval"
            android:textColor="#FFFFFF"
            app:backgroundTint="#00C00D"
            app:cornerRadius="0dp"
            android:textSize="35dp"
            android:textStyle="bold"
            android:layout_margin="5dp"
            />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:weightSum="3"
            >
            <TextView
                android:id="@+id/scoreText"
                android:text="Correct: 0"
                android:textSize="18sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@android:color/holo_green_dark"
                android:padding="12dp"
                android:textStyle="bold"
                />
            <TextView
                android:id="@+id/wrongText"
                android:text="Wrong: 0"
                android:textSize="18sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@android:color/holo_red_dark"
                android:padding="12dp"
                android:textStyle="bold"
                />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnReplayInterval"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Replay Interval"
                android:textColor="#FFFFFF"
                app:backgroundTint="#FF0000"
                app:cornerRadius="0dp"
                android:textSize="23dp"
                android:textStyle="bold"
                />

        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:orientation="horizontal"
            android:background="@color/black"
            android:layout_weight="1"
            android:weightSum="2"
            >
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMinorSecond"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Minor 2nd"
                android:textColor="#FFFFFF"
                app:backgroundTint="#3F51B5"
                app:cornerRadius="0dp"
                android:textSize="20dp"
                android:textStyle="bold"
                android:layout_margin="5dp"
                />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMajorSecond"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Major 2nd"
                android:textColor="#FFFFFF"
                app:backgroundTint="#E91E63"
                app:cornerRadius="0dp"
                android:textSize="20dp"
                android:textStyle="bold"
                android:layout_margin="5dp"
                />


        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:orientation="horizontal"
            android:background="@color/black"
            android:layout_weight="1"
            android:weightSum="2"
            >
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMinorThird"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Minor 3rd"
                android:textColor="#FFFFFF"
                app:backgroundTint="#FFC73B"
                app:cornerRadius="0dp"
                android:textSize="20dp"
                android:textStyle="bold"
                android:layout_margin="5dp"
                />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMajorThird"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Major 3rd"
                android:textColor="#FFFFFF"
                app:backgroundTint="#00BCD4"
                app:cornerRadius="0dp"
                android:textSize="20dp"
                android:textStyle="bold"
                android:layout_margin="5dp"
                />


        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:orientation="horizontal"
            android:background="@color/black"
            android:layout_weight="1"
            android:weightSum="2"
            >
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPerfectFourth"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Perfect Fourth"
                android:textColor="#FFFFFF"
                app:backgroundTint="#FF0FF8"
                app:cornerRadius="0dp"
                android:textSize="20dp"
                android:textStyle="bold"
                android:layout_margin="5dp"
                />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPerfectFifth"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Perfect Fifth"
                android:textColor="#FFFFFF"
                app:backgroundTint="#0029FF"
                app:cornerRadius="0dp"
                android:textSize="20dp"
                android:textStyle="bold"
                android:layout_margin="5dp"
                />


        </LinearLayout>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOctave"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:text="Octave"
            android:textColor="#FFFFFF"
            app:backgroundTint="#8D66FF"
            app:cornerRadius="0dp"
            android:textSize="35dp"
            android:textStyle="bold"
            android:layout_margin="5dp"
            />
    </LinearLayout>


</androidx.constraintlayout.widget.ConstraintLayout>